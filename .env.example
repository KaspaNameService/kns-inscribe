# Kaspa node connection
NODE_IP=127.0.0.1
NODE_WS_PORT=17110

# Network: mainnet | testnet-10 | devnet | simnet
NETWORK_ID=mainnet

# Private key (hex, 32 bytes / 64 chars) — keep secret!
PRIVATE_KEY=your_private_key_hex_here

# KNS registration fee payment address (optional)
# If unset, fees are returned to the sender address
KNS_FUNDS_ADDRESS=kaspa:your_kns_funds_address_here
